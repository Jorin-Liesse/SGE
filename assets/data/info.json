{
    "project": "SGE",
    "company": "Sapodilla-Games",
    "version": "0.1.0",
    "description": "A simple game engine using SDL3",
    "author": "Jorin Liesse",
    "license": "MIT",
    "credits": [
        {
            "name": "sdl3-sample",
            "author": "Ravbug",
            "website": "https://www.ravbug.com/",
            "license": "CC0 1.0 Universal",
            "link": "https://github.com/Ravbug/sdl3-sample"
        },
        {
            "name": "cJSON",
            "author": "Dave Gamble",
            "website": "https://github.com/DaveGamble",
            "license": "MIT",
            "link": "https://github.com/DaveGamble/cJSON"
        }
    ],

    "music-track-pool-size": 5,
    "sound-effect-track-pool-size": 10,

    "manifest-orientation": "landscape",
    "manifest-window-mode": "fullscreen",

    "default-width": 1280,
    "default-height": 720,
    "default-window-mode": "windowed",

    "default-fps": 60,
    "default-vsync": true,

    "default-audio-volume": 1,
    "default-music-volume": 1,
    "default-sound-volume": 1,

    "icon-path": "assets/icons/icon.png",
    "assets-path": "assets",
    "resources-path": "resources",
    "include-path": "include",
    "source-path": "src"
}
